<p>{{ page.url }} : <strong>{{ page.title }}</strong></p>

<table style="margin-bottom: 1em;">
    <tr>
        <td>ID:</td>
        <td>{{ comment.id }}</td>
    </tr>
    <tr>
        <td>URL:</td>
        <td>{{ page.url }}</td>
    </tr>
    <tr>
        <td>{{ 'PLUGIN_ZSCOMMENTS.NAME_LABEL'|t }}:</td>
        <td>{{comment.author}}</td>
    </tr>
    <tr>
        <td>{{ 'PLUGIN_ZSCOMMENTS.EMAIL_LABEL'|t }}:</td>
        <td>{{comment.email}}</td>
    </tr>
    <tr>
        <td>{{ 'PLUGIN_ZSCOMMENTS.MESSAGE_LABEL'|t }}:</td>
        <td>{{comment.text}}</td>
    </tr>
</table>

<form method='GET' action='{{ base_uri }}/zscomments-approve'>
  <input type='hidden' name='id' value='{{ comment.id }}'>
  <input type='hidden' name='url' value='{{ page.url }}'>
  <div>
    <label>{{ 'PLUGIN_ZSCOMMENTS.QUICK_REPLY_LABEL'|t }}</label>
  </div>
  <textarea name='quickreply' rows='4' cols='60'></textarea>
  <div>
    <button type='submit' class='button button-positive'>Approve comment!</button>
  </div>
</form>

<form method='GET' action='{{ base_uri }}/zscomments-delete'>
  <input type='hidden' name='id' value='{{ comment.id }}'>
  <input type='hidden' name='url' value='{{ page.url }}'>

  <div>
    <button type='submit'>Delete comment!</button>
  </div>
</form>

